{
  "name": "verify-it",
  "version": "2.4.0",
  "description": "Randomised test property/data generation for NodeJS",
  "keywords": [
    "testing",
    "test",
    "randomization",
    "random",
    "data",
    "property",
    "generation",
    "generator"
  ],
  "main": "index.js",
  "scripts": {
    "test": "npm run test:unit && npm run test:unit-native && npm run test:format && npm run test:types && npm run test:docs && npm run check-dependencies",
    "test:unit": "JUNIT_REPORT_PATH=test/test-reports/report.xml nyc --all --include=index.js --include=src/*.js --include=src/*/**.js --reporter=html --reporter=text mocha test/*.js test/**/*.js",
    "test:unit-native": "node --test test/NativeTestingLibrary.spec.js",
    "test:format": "prettier --write .",
    "test:types": "tsc test/types/*.spec.ts",
    "test:docs": "typescript-docs-verifier",
    "check-dependencies": "scripts/spdx-non-copyleft.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bbc/verify-it.git"
  },
  "author": "BBC",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/bbc/verify-it/issues"
  },
  "engines": {
    "node": ">=6"
  },
  "homepage": "https://github.com/bbc/verify-it#readme",
  "dependencies": {
    "random-js": "^2.1.0"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.10.15",
    "chai": "^4.5.0",
    "chai-as-promised": "^7.1.2",
    "license-checker": "^25.0.1",
    "mocha": "^11.7.5",
    "nyc": "^17.1.0",
    "prettier": "^3.8.1",
    "spdx-copyleft": "^1.0.0",
    "testdouble": "^3.20.2",
    "typescript": "^5.9.3",
    "typescript-docs-verifier": "^3.0.1"
  },
  "files": [
    "src",
    "index.js",
    "index.d.ts",
    "LICENSE"
  ]
}
